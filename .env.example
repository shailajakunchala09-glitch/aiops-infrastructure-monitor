# Copy to .env and adjust for your environment.
ENVIRONMENT=development
DEBUG=true

SECRET_KEY=replace-with-a-long-random-secret-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

DATABASE_URL=postgresql+psycopg2://aiops_user:aiops_password@db:5432/aiops_db

CORS_ORIGINS=["http://localhost:3000"]

DEFAULT_CPU_THRESHOLD=85
DEFAULT_MEMORY_THRESHOLD=85
DEFAULT_DISK_THRESHOLD=90
METRIC_RETENTION_DAYS=90
ALERT_EVALUATION_INTERVAL_SECONDS=30
